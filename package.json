{
  "name": "@minamijogen/openclaw-wechat",
  "version": "0.1.0",
  "description": "Reuse QClaw's private WeChat gateway in OpenClaw with QR pairing. 在 OpenClaw 中复用 QClaw 私有微信通路，并支持扫码配对。",
  "keywords": [
    "openclaw",
    "qclaw",
    "wechat",
    "plugin"
  ],
  "homepage": "https://github.com/MinamiJogen/openclaw-wechat#readme",
  "bugs": {
    "url": "https://github.com/MinamiJogen/openclaw-wechat/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MinamiJogen/openclaw-wechat.git"
  },
  "license": "ISC",
  "author": "MinamiJogen",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "build": "npm run typecheck",
    "typecheck": "npx -y -p typescript tsc --noEmit"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {},
  "peerDependencies": {
    "openclaw": ">=2026.1.26"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "channel": {
      "id": "wechat-access",
      "label": "QClaw 微信通路",
      "selectionLabel": "QClaw 微信通路",
      "detailLabel": "QClaw 微信通路",
      "docsPath": "/channels/wechat-access",
      "docsLabel": "wechat-access",
      "blurb": "Reuse QClaw's private WeChat gateway with QR pairing.",
      "order": 85
    },
    "install": {
      "npmSpec": "@minamijogen/openclaw-wechat",
      "localPath": ".",
      "defaultChoice": "npm"
    }
  }
}
